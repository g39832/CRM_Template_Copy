SUPABASE_URL=
SUPABASE_ANON_KEY=
PORT=3000

# Optional environment variables for the full template experience
SESSION_SECRET=
DEFAULT_ADMIN_PASSWORD=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=crm-files

# Optional email sender fallback. The app can also store these in Email Setup.
EMAIL_PROVIDER=gmail
EMAIL_USER=
EMAIL_PASS=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_FROM_NAME=
EMAIL_FROM_EMAIL=
EMAIL_REPLY_TO=
ENABLE_DB_BACKUPS=false
DISABLE_AUTH=false
