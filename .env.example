SUPABASE_URL=
SUPABASE_ANON_KEY=
PORT=3000
STORAGE_BACKEND=auto
SESSION_COOKIE_SECURE=false

# Optional environment variables for the full template experience
SESSION_SECRET=
DEFAULT_ADMIN_PASSWORD=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=crm-files

# Optional brand fallback. Company Profile in the app can override these.
BUSINESS_NAME=
BUSINESS_ADDRESS=
BUSINESS_PHONE=
BUSINESS_EMAIL=

# Optional email sender fallback for future outbound-email workflows.
EMAIL_PROVIDER=gmail
EMAIL_USER=
EMAIL_PASS=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_FROM_NAME=
EMAIL_FROM_EMAIL=
EMAIL_REPLY_TO=
ENABLE_DB_BACKUPS=false
DISABLE_AUTH=false

# === Cron Job Security ===
# Used to authenticate Render Cron Jobs when calling /api/v2/dashboard/recurring-cron
CRON_SECRET=change-this-to-a-random-secret-in-production

# === Onboarding & Multi-tenant ===
NODE_ENV=development
